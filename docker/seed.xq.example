xquery version "3.1";

(: Copy to docker/seed.xq for local builds, then set the account password.
   CI writes docker/seed.xq from the SEED_XQ repository secret.
   Used as a Docker build secret (id=seed); not copied into the image.

   BetaMasaheftAdmin must exist before this repo's own package installs:
   repo.xml declares <permissions user="BetaMasaheftAdmin" group="dba" .../>
   for its own collection, and the base image (BETMAS_DATA_IMAGE) does not
   create this account. Nothing else needs seeding here: the real corpus is
   already provided by the base image. :)

if (sm:user-exists("BetaMasaheftAdmin")) then () else
  sm:create-account("BetaMasaheftAdmin", "changeme", "dba")
