{
	"name": "betmas-web",
	"version": "1.0.0",
	"description": "BetMasWeb - Exist-db application",
	"private": true,
	"devDependencies": {
		"cypress": "^15.18.1",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"prettier": "^3.9.4",
		"prettier-plugin-xquery": "^1.6.2"
	},
	"scripts": {
		"format:check": "prettier --check .",
		"format:write": "prettier --write . && prettier --write .",
		"test": "cypress run",
		"prepare": "husky"
	},
	"lint-staged": {
		"*": [
			"prettier --write --ignore-unknown",
			"prettier --write --ignore-unknown"
		]
	}
}
