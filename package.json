{
	"name": "betmas-web",
	"version": "1.0.0",
	"description": "BetMasWeb - Exist-db application",
	"private": true,
	"devDependencies": {
		"@existdb/xst": "^4.1.2",
		"cypress": "^15.19.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.1.1",
		"prettier": "^3.9.6",
		"prettier-plugin-xquery": "^1.6.2"
	},
	"scripts": {
		"format:check": "prettier --check .",
		"format:write": "prettier --write . && prettier --write .",
		"test": "cypress run",
		"deploy:dev": "ant && EXISTDB_SERVER=http://localhost:8080 EXISTDB_USER=admin EXISTDB_PASS= xst package install local-files build/*.xar",
		"prepare": "husky"
	},
	"lint-staged": {
		"*": [
			"prettier --write --ignore-unknown",
			"prettier --write --ignore-unknown"
		]
	}
}
